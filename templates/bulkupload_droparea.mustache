<div id="not_supported_browser" class="error">
  {{#str}} notsupportedbrowser, mod_videoassessment {{/str}}
</div>

<form>
  <input type="file" name="fileToUpload" id="fileToUpload">

  <fieldset id="droparea" style="display:none;">
    <legend>{{#str}} dropvideofileshere, mod_videoassessment {{/str}}</legend>

    <div id="scrollarea">
      <table id="tasklist">
        <thead>
          <tr>
            <th class="filename">{{#str}} uploadfilename, mod_videoassessment {{/str}}</th>
            <th class="filesize">{{#str}} uploadfilesize, mod_videoassessment {{/str}}</th>
            <th class="mimetype">{{#str}} uploadmimetype, mod_videoassessment {{/str}}</th>
            <th class="status">{{#str}} uploadstatus, mod_videoassessment {{/str}}</th>
            <th class="progress">{{#str}} uploadprogress, mod_videoassessment {{/str}}</th>
          </tr>
        </thead>
        <tbody>
          {{! rows will be added dynamically by JS }}
        </tbody>
      </table>
    </div>
  </fieldset>
</form>
